{
  "rewrites": [
    { "source": "/digital-scanner", "destination": "https://next-dental-lab-scanner.vercel.app" },
    { "source": "/digital-scanner/:path*", "destination": "https://next-dental-lab-scanner.vercel.app/:path*" },
    { "source": "/_next/:path*", "destination": "https://next-dental-lab-scanner.vercel.app/_next/:path*" },
    { "source": "/images/:path*", "destination": "https://next-dental-lab-scanner.vercel.app/images/:path*" },
    { "source": "/favicon.ico", "destination": "https://next-dental-lab-scanner.vercel.app/favicon.ico" }
  ]
}